# Alsat API Konfigürasyonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun

PORT=3001

# Veritabanı seçimi: postgres | mysql | sqlite
DB_DRIVER=sqlite

# PostgreSQL (DB_DRIVER=postgres)
# DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/alsat

# MySQL (DB_DRIVER=mysql)
# DATABASE_URL=mysql://kullanici:sifre@localhost:3306/alsat

# SQLite varsayılan (DB_DRIVER=sqlite) - .env gerekmez
# ./alsat.db kullanılır

# JWT — production'da ZORUNLU (varsayılan secret ile sunucu başlamaz)
# JWT_SECRET=guclu-rastgele-uzun-gizli-anahtar
# JWT_EXPIRES=7d
# JWT_REFRESH_EXPIRES=30d

# Güvenlik
# RATE_LIMIT_MAX=100
# Yayında: CORS_ORIGINS=https://alsatmk.com,https://www.alsatmk.com
# Boş bırakırsanız tüm origin'lere izin verilir

# Admin Reset (POST /api/admin/reset)
# ADMIN_EMAIL=info@alsatmk.com
# ADMIN_RESET_TOKEN=guclu-sifre  (X-Admin-Token header; boşsa token kontrolü yok)

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
# RECAPTCHA_SITE_KEY=6Lc...
# RECAPTCHA_SECRET_KEY=6Lc...

# Web Push (VAPID - npm run vapid:generate ile üret)
# VAPID_PUBLIC_KEY=BN...
# VAPID_PRIVATE_KEY=...

# Site URL (e-postalardaki linkler için - www.alsatmk.com)
# SITE_URL=https://www.alsatmk.com

# Yeni ilan durumu: boş veya approved = doğrudan yayın; pending = yönetici onayı kuyruğu
# Yeni ilanlar: approved (doğrudan yayın) | pending (yönetici onayı).
# Yerelde varsayılan approved; Railway/production’da ADS_DEFAULT_STATUS=pending kullanın.
# ADS_DEFAULT_STATUS=pending

# E-posta — Railway vb. ortamlarda SMTP (587) çoğu planda engellenir; HTTPS API kullanın:
# RESEND_API_KEY=re_...   https://resend.com — domain doğrulayıp RESEND_FROM ayarlayın
# veya SENDGRID_API_KEY=SG...
# RESEND_FROM="Alsat <noreply@sizin-domain.com>"
#
# SMTP sadece kendi sunucunuzda / SMTP izinli planda:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=info@alsatmk.com
# SMTP_PASS=gmail-uygulama-sifresi
# MAIL_FROM="Alsat" <info@alsatmk.com>
