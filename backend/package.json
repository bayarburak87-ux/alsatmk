{
  "name": "alsat-api",
  "version": "1.0.0",
  "description": "Alsat 2. el ilan platformu API - Node.js + PostgreSQL/MySQL/SQLite",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:init": "node db/init.js",
    "test": "jest --testPathIgnorePatterns=node_modules",
    "cron:search-alerts": "node jobs/search-alert-cron.js",
    "cron:price-alerts": "node jobs/price-alert-cron.js",
    "vapid:generate": "node -e \"const w=require('web-push'); const v=w.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+v.publicKey); console.log('VAPID_PRIVATE_KEY='+v.privateKey);\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "mysql2": "^3.6.5",
    "better-sqlite3": "^9.2.2",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.5.1",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18"
  }
